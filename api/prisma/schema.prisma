// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessionMemberships PairSessionMember[]
  sessionEvents      SessionEvent[]
  reviewSubmissions  ReviewSubmission[]

  @@map("users")
}

model Topic {
  id          String @id @default(cuid())
  name        String @unique
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  questions Question[]

  @@map("topics")
}

model Question {
  id                String @id @default(cuid())
  topicId           String
  title             String
  description       String
  difficulty        String
  starterCode       String   @default("")
  referenceSolution String
  reviewQuestions   Json   // Array of review questions
  conceptTags       Json   // Array of concept tags
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  topic   Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sessions PairSession[]

  @@map("questions")
}

model PairSession {
  id           String    @id @default(cuid())
  joinCode     String    @unique
  questionId   String
  status       String    @default("ACTIVE") // ACTIVE, COMPLETED
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  finalCode    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  question    Question            @relation(fields: [questionId], references: [id])
  members     PairSessionMember[]
  events      SessionEvent[]
  snapshots   CodeSnapshot[]
  windows     FeatureWindow[]
  predictions PairStatePrediction[]
  interventions Intervention[]
  reviews     ReviewSubmission[]

  @@map("pair_sessions")
}

model PairSessionMember {
  id       String @id @default(cuid())
  sessionId String
  userId    String
  role      String // DRIVER, NAVIGATOR
  joinedAt  DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("pair_session_members")
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  role      String
  eventType String // CODE_EDIT, CODE_DELETE, RUN_ATTEMPT, RUN_SUCCESS, RUN_FAILURE, ROLE_SWITCH, DISCUSSION_NOTE, IDLE_PERIOD
  timestamp DateTime @default(now())
  metadata  Json     // Event-specific data

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session_events")
}

model CodeSnapshot {
  id        String   @id @default(cuid())
  sessionId String
  code      String
  timestamp DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("code_snapshots")
}

model FeatureWindow {
  id          String   @id @default(cuid())
  sessionId   String
  windowStart DateTime
  windowEnd   DateTime
  features    Json     // Extracted features
  createdAt   DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("feature_windows")
}

model PairStatePrediction {
  id           String   @id @default(cuid())
  sessionId    String
  windowStart  DateTime
  windowEnd    DateTime
  predictedState String
  confidence   Float
  modelVersion String
  createdAt    DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("pair_state_predictions")
}

model Intervention {
  id        String   @id @default(cuid())
  sessionId String
  state     String
  action    String
  uiTarget  String
  uiEffect  String
  message   String
  shownAt   DateTime @default(now())
  accepted  Boolean?
  createdAt DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interventions")
}

model ReviewSubmission {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  answers    Json     // Array of True/False answers
  score      Int
  completedAt DateTime @default(now())

  // Relations
  session PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("review_submissions")
}

model RAGDocument {
  id          String   @id @default(cuid())
  title       String
  content     String
  source      String
  conceptTags Json     // Array of concept tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  chunks RAGChunk[]

  @@map("rag_documents")
}

model RAGChunk {
  id           String   @id @default(cuid())
  documentId   String
  chunkText    String
  conceptTag   String
  embedding    Json?    // Vector embedding
  createdAt    DateTime @default(now())

  // Relations
  document RAGDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("rag_chunks")
}
